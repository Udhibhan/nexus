# Supabase — get these from your project's Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# MQTT — HiveMQ free cloud (https://console.hivemq.cloud)
# Use the free cluster. Browser connects via WSS, Arduino via TCP.
NEXT_PUBLIC_MQTT_BROKER_WSS=wss://YOUR_CLUSTER.s2.eu.hivemq.cloud:8884/mqtt
NEXT_PUBLIC_MQTT_USERNAME=your_hivemq_username
NEXT_PUBLIC_MQTT_PASSWORD=your_hivemq_password

# Topic prefix — change this so you don't clash with others
NEXT_PUBLIC_MQTT_TOPIC_PREFIX=mbot_epp_2025
